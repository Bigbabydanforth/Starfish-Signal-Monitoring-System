# =============================================
# Starfish Signal Monitor — Environment Variables
# Copy this file to .env and fill in all values
# NEVER commit .env to Git
# =============================================

# --- Apollo API (Job Change Tracking) ---
APOLLO_API_KEY=
APOLLO_API_URL=https://api.apollo.io/v1

# --- MediaStack API (News & Press Monitoring) ---
MEDIASTACK_API_KEY=
MEDIASTACK_API_URL=https://api.mediastack.com/v1

# --- PDL API (Primary Job Change Source) ---
PDL_API_KEY=

# --- NewsAPI (M&A & Funding News) ---
NEWSAPI_API_KEY=
NEWSAPI_API_URL=https://newsapi.org/v2

# --- PredictLeads API (M&A Activity Tracking) ---
PREDICTLEADS_API_KEY=
PREDICTLEADS_API_TOKEN=
# Base URL — v3 only (the v1 endpoint is deprecated)
PREDICTLEADS_API_URL=https://predictleads.com/api/v3

# --- Hunter API (Email Enrichment — email-finder + domain-search + verify) ---
HUNTER_API_KEY=your_hunter_api_key_here

# --- Claude API (Anthropic — Signal Enrichment) ---
CLAUDE_API_KEY=
CLAUDE_API_URL=https://api.anthropic.com/v1
# Default: claude-haiku-4-5-20251001 (cheaper, faster — good for enrichment)
# For higher quality: claude-sonnet-4-6
CLAUDE_MODEL=claude-haiku-4-5-20251001

# --- Airtable (Live Signal Database) ---
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Signals

# --- Email / SMTP (Gmail) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Starfish Signal Monitor <noreply@starfishmonitor.com>
EMAIL_TO_TESTING=
EMAIL_TO_PRODUCTION=

# --- Google Sheets (Client-facing signal view) ---
GOOGLE_SHEET_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# --- Telegram (Silent Monitoring — Gideon only) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- System ---
NODE_ENV=development
TZ=America/New_York
CRON_SCHEDULE=0 5 * * *
